# ===========================================
# DCVS Environment Variables
# ===========================================
# Copy this file to .env.local (frontend) and/or .env (blockchain)
# and fill in the appropriate values.

# --- Frontend (Next.js) ---
# Contract address (auto-generated by deploy script, or set manually)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# RPC URL for the blockchain network
# Local Hardhat: http://localhost:8545
# Sepolia:       https://sepolia.infura.io/v3/YOUR_KEY
NEXT_PUBLIC_RPC_URL=http://localhost:8545

# Chain ID (hex)
# Hardhat: 0x7a69 (31337)
# Sepolia: 0xaa36a7 (11155111)
NEXT_PUBLIC_CHAIN_ID=0x7a69

# --- Pinata IPFS ---
# Get your keys at https://app.pinata.cloud/developers/api-keys
# If not set, the app will use mock IPFS CIDs for local development.
PINATA_API_KEY=
PINATA_API_SECRET=

# --- Blockchain Deployment (Sepolia Testnet) ---
# WARNING: Never commit real private keys!
# Use a dedicated testnet wallet funded via a faucet.
SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=
